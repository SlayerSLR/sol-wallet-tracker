{
  "name": "solana-wallet-tracker",
  "version": "1.0.0",
  "description": "Track trades of 500+ Solana wallets with persistence and real-time streaming",
  "main": "dist/main/index.js",
  "scripts": {
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:rust": "cd rust/pump-tool && cargo build --release",
    "build": "tsc",
    "start": "npm run rebuild && npm run build:rust && npm run build && electron .",
    "dev": "npm run rebuild && npm run build:rust && tsc && electron .",
    "server": "node dist/server/index.js --db-path=./data/tracker.db",
    "server:install": "npm rebuild better-sqlite3",
    "server:dev": "tsc && npx electron ./dist/server/index.js",
    "pack": "npm run rebuild && npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "solana",
    "wallet-tracker",
    "pumpfun"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.7.0"
  }
}
